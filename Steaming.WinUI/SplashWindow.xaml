<Window
    x:Class="Steaming.WinUI.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Rob's Streaming Console">

    <Border Background="#FF1E1E1E" BorderBrush="#FF464646" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- Logo + title + version -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,40,0,28">
                <Image x:Name="LogoImage" Width="72" Height="72" HorizontalAlignment="Center"/>
                <TextBlock Text="Rob's Streaming Console" FontSize="22" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,14,0,4"/>
                <TextBlock x:Name="VersionText" FontSize="13" Foreground="#FFABABAB"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Status + progress -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                <TextBlock x:Name="StatusText" Text="Loading..." FontSize="13" Foreground="#FFABABAB"
                           HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Width="220" Height="3"
                             Background="#FF3A3A3A"/>
            </StackPanel>

            <!-- Bottom watermark -->
            <TextBlock Grid.Row="2"
                       FontSize="11" Foreground="#FF484848"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                Rob's Streaming Console
            </TextBlock>
        </Grid>
    </Border>
</Window>
