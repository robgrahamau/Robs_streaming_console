<Page
    x:Class="Steaming.WinUI.Pages.StreamPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="680">

            <TextBlock Text="Stream Management" FontSize="20" FontWeight="SemiBold"/>

            <!-- Stream health -->
            <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="STREAM HEALTH" FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock x:Name="HealthLabel" FontSize="13"/>
                    <TextBlock x:Name="HealthWarnLabel" FontSize="12" Foreground="Orange" TextWrapping="Wrap"/>
                    <TextBlock Text="Warn me if a destination becomes unhealthy while streaming:" FontSize="12"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox x:Name="WarnTwitchCheck" Content="Twitch"
                                  Checked="WarnTwitch_Toggled" Unchecked="WarnTwitch_Toggled"/>
                        <CheckBox x:Name="WarnKickCheck" Content="Kick"
                                  Checked="WarnKick_Toggled" Unchecked="WarnKick_Toggled"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Current metadata -->
            <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="CURRENT METADATA" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Refresh" Click="RefreshMeta_Click"
                                FontSize="12" Height="28"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="4">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Twitch title:" FontSize="12"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock x:Name="TwitchTitleLabel" Grid.Row="0" Grid.Column="1" FontSize="12"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Kick title:" FontSize="12"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock x:Name="KickTitleLabel" Grid.Row="1" Grid.Column="1" FontSize="12"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Category:" FontSize="12"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock x:Name="CategoryLabel" Grid.Row="2" Grid.Column="1" FontSize="12"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Update title -->
            <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="UPDATE TITLE" FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox x:Name="TitleBox" PlaceholderText="New stream title" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <CheckBox x:Name="TitleTwitchCheck" Content="Twitch" IsChecked="True"/>
                        <CheckBox x:Name="TitleKickCheck"   Content="Kick"   IsChecked="True"/>
                        <Button Content="Update Title" Click="UpdateTitle_Click"/>
                        <TextBlock x:Name="TitleResult" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Update category -->
            <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="UPDATE CATEGORY" FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox x:Name="SearchBox" Grid.Column="0" PlaceholderText="Search games / categories..."
                                 KeyDown="SearchBox_KeyDown"/>
                        <Button  x:Name="SearchBtn" Grid.Column="1" Content="Search" Click="Search_Click"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <CheckBox x:Name="GameTwitchCheck" Content="Twitch" IsChecked="True"/>
                        <CheckBox x:Name="GameKickCheck"   Content="Kick"   IsChecked="True"/>
                    </StackPanel>
                    <ListView x:Name="GameResults" MaxHeight="200" SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="13" Padding="2,4"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Apply Category" Click="ApplyGame_Click"/>
                        <TextBlock x:Name="GameResult" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
