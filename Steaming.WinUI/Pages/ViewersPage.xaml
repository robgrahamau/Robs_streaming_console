<Page
    x:Class="Steaming.WinUI.Pages.ViewersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Grid RowDefinitions="Auto,*">

        <Border Grid.Row="0"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock x:Name="ViewerCountLabel" FontSize="13" VerticalAlignment="Center"/>
                <Button Content="Refresh" Click="Refresh_Click" Height="28" FontSize="12"/>
            </StackPanel>
        </Border>

        <ListView x:Name="ViewerList" Grid.Row="1" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Platform}" FontSize="11" Width="52"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DisplayName}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
