<Page
    x:Class="Steaming.WinUI.Pages.ActivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Grid RowDefinitions="*,Auto">

        <ListView x:Name="ActivityList" Grid.Row="0"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="13" Padding="2,2"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="1"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0" Padding="12,6">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock x:Name="CountLabel" FontSize="11" VerticalAlignment="Center"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <CalendarDatePicker x:Name="HistoryDatePicker"
                                       PlaceholderText="Load date..."
                                       FontSize="11"/>
                    <Button Content="Load" FontSize="11" Padding="10,2"
                            ToolTipService.ToolTip="Load activity history for the selected date"
                            Click="LoadDate_Click"/>
                    <Button Content="Clear" FontSize="11" Padding="10,2"
                            ToolTipService.ToolTip="Clear the feed — history stays in the database"
                            Click="Clear_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Page>
