<Page
    x:Class="Steaming.WinUI.Pages.ConnectionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="700">

            <!-- Twitch -->
            <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Twitch" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TwitchStatusLabel" FontSize="13"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <Ellipse x:Name="TwitchDot" Grid.Column="1" Width="12" Height="12"
                                 VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13"
                                   Text="Active — stream to Twitch (off = ignore it without logging out)"/>
                        <ToggleSwitch x:Name="TwitchActiveToggle" Grid.Column="1" MinWidth="0"
                                      OnContent="" OffContent="" VerticalAlignment="Center"
                                      Toggled="TwitchActive_Toggled"/>
                    </Grid>
                    <Button x:Name="TwitchLoginBtn" Content="Connect Twitch" Click="TwitchLogin_Click"/>
                </StackPanel>
            </Border>

            <!-- Kick -->
            <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Kick" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="KickStatusLabel" FontSize="13"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <Ellipse x:Name="KickDot" Grid.Column="1" Width="12" Height="12"
                                 VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13"
                                   Text="Active — stream to Kick (off = ignore it without logging out)"/>
                        <ToggleSwitch x:Name="KickActiveToggle" Grid.Column="1" MinWidth="0"
                                      OnContent="" OffContent="" VerticalAlignment="Center"
                                      Toggled="KickActive_Toggled"/>
                    </Grid>
                    <Button x:Name="KickLoginBtn" Content="Connect Kick" Click="KickLogin_Click"/>

                    <!-- Unsupported Kick extras: uses Kick's unofficial browser/Pusher path for items
                         the official integration does not provide here (raids + follower totals). -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Unsupported Kick extras" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="KickRaidStatusLabel" FontSize="12" TextWrapping="Wrap"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="KickRaidToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Toggled="KickRaidToggle_Toggled"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- YouTube -->
            <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="YouTube" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="YouTubeStatusLabel" FontSize="13"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <Ellipse x:Name="YouTubeDot" Grid.Column="1" Width="12" Height="12"
                                 VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13"
                                   Text="Active — stream to YouTube (off = ignore it without logging out)"/>
                        <ToggleSwitch x:Name="YouTubeActiveToggle" Grid.Column="1" MinWidth="0"
                                      OnContent="" OffContent="" VerticalAlignment="Center"
                                      Toggled="YouTubeActive_Toggled"/>
                    </Grid>
                    <Button x:Name="YouTubeLoginBtn" Content="Connect YouTube" Click="YouTubeLogin_Click"/>
                </StackPanel>
            </Border>

            <!-- Kick Bridge -->
            <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Kick Bridge" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="BridgeStatusLabel" FontSize="13" TextWrapping="Wrap"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>

                    <!-- Settings grid -->
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="8" ColumnSpacing="12">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Enabled" VerticalAlignment="Center"/>
                        <ToggleSwitch x:Name="BridgeEnabled" Grid.Row="0" Grid.Column="1"
                                      OnContent="" OffContent="" MinWidth="0"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Host" VerticalAlignment="Center"/>
                        <TextBox x:Name="BridgeHost" Grid.Row="1" Grid.Column="1"
                                 PlaceholderText="e.g. bridge.example.com"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Port" VerticalAlignment="Center"/>
                        <TextBox x:Name="BridgePort" Grid.Row="2" Grid.Column="1"
                                 PlaceholderText="7449"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Use TLS" VerticalAlignment="Center"/>
                        <ToggleSwitch x:Name="BridgeUseTls" Grid.Row="3" Grid.Column="1"
                                      OnContent="" OffContent="" MinWidth="0"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="WebSocket Path" VerticalAlignment="Center"/>
                        <TextBox x:Name="BridgePath" Grid.Row="4" Grid.Column="1"
                                 PlaceholderText="/ws/kick-bridge"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Client Token" VerticalAlignment="Center"/>
                        <PasswordBox x:Name="BridgeToken" Grid.Row="5" Grid.Column="1"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Allow Outbound Chat" VerticalAlignment="Center"/>
                        <ToggleSwitch x:Name="BridgeAllowOutbound" Grid.Row="6" Grid.Column="1"
                                      OnContent="" OffContent="" MinWidth="0"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Save" Click="BridgeSave_Click"/>
                        <Button Content="Connect Bridge" Click="BridgeConnect_Click"/>
                        <Button Content="Disconnect" Click="BridgeDisconnect_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- OBS WebSocket -->
            <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="OBS WebSocket" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ObsStatusLabel" FontSize="13"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <Ellipse x:Name="ObsDot" Grid.Column="1" Width="12" Height="12"
                                 VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="8">
                        <TextBox x:Name="ObsAddressBox" Grid.Column="0" PlaceholderText="ws://localhost:4455"/>
                        <PasswordBox x:Name="ObsPasswordBox" Grid.Column="1" PlaceholderText="Password (optional)"/>
                        <Button Grid.Column="2" Content="Connect" Click="ObsConnect_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
