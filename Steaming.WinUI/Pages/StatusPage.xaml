<Page
    x:Class="Steaming.WinUI.Pages.StatusPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="860">

            <TextBlock Text="Runtime Status" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Service state for optional providers and degraded features is shown here."
                       FontSize="13" TextWrapping="Wrap"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>

            <ListView x:Name="StatusList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="8" Padding="0" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="12,*">
                                <!-- Color bar matching the state accent -->
                                <Border Grid.Column="0" Background="{Binding Accent}" CornerRadius="8,0,0,8"/>
                                <StackPanel Grid.Column="1" Spacing="4" Padding="14,12,14,12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   FontSize="15" FontWeight="SemiBold"/>
                                        <Border Grid.Column="1" Background="#14FFFFFF"
                                                BorderBrush="{Binding Accent}" BorderThickness="1"
                                                CornerRadius="10" Padding="8,2">
                                            <TextBlock Text="{Binding State}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding Accent}"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding Summary}" FontSize="13" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Details}" FontSize="12" TextWrapping="Wrap"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>
