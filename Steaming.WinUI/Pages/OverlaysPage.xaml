<Page
    x:Class="Steaming.WinUI.Pages.OverlaysPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Grid ColumnDefinitions="500,*">

        <!-- â”€â”€ Left column: overlay list â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
        <ScrollViewer Grid.Column="0"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="0,0,1,0">
            <StackPanel Spacing="4" Padding="10,12,10,12">

                <Button HorizontalAlignment="Stretch" Click="ShowTokenHelp_Click"
                        Content="&#x2139; Text variables ({user}, {platform}, &#x2026;)" FontSize="12"
                        ToolTipService.ToolTip="Show every variable you can use in alert text"/>

                <!-- â”€â”€ ALERT EVENTS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
                <TextBlock Text="ALERT EVENTS" FontSize="10" FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           Margin="2,0,0,4" CharacterSpacing="80"/>

                <!-- Follow -->
                <Expander x:Name="FollowExpander"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="6"
                              Margin="0,2,0,2">
                            <CheckBox x:Name="FollowEnabled" Click="EventEnabled_Click" Grid.Column="0"
                                      VerticalAlignment="Center" MinWidth="0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="Follow" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock x:Name="FollowCustomTag" Text="&#x25C6; custom" FontSize="11" Foreground="#FF8C00" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="&#x1F441;" FontSize="11"
                                    Click="PreviewFollow_Click" ToolTipService.ToolTip="Preview"/>
                            <Button Grid.Column="3" Content="&#x25B6;" FontSize="11"
                                    Click="TestFollow_Click" ToolTipService.ToolTip="Test"/>
                            <Button Grid.Column="4" Content="&#x270F;" FontSize="11"
                                    Click="EditLayoutFollow_Click" ToolTipService.ToolTip="Edit Layout"/>
                        </Grid>
                    </Expander.Header>
                    <StackPanel Spacing="8" Padding="4,6,4,6">
                        <TextBlock Text="Alert text â€” use {user} for username"
                                   FontSize="11"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox x:Name="FollowText" PlaceholderText="Alert text"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Duration (sec)" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="FollowDuration" PlaceholderText="5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="Volume (0â€“1)" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="FollowVolume" PlaceholderText="1.0"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox x:Name="FollowSound" Grid.Column="0"
                                     PlaceholderText="Sound file (optional)" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="Browse"
                                    Click="BrowseFollowSound_Click" FontSize="11"/>
                        </Grid>
                        <Button Content="Save" Click="SaveFollow_Click"
                                Style="{ThemeResource AccentButtonStyle}" FontSize="11"/>
                    </StackPanel>
                </Expander>

                <!-- Subscribe -->
                <Expander x:Name="SubscribeExpander"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="6"
                              Margin="0,2,0,2">
                            <CheckBox x:Name="SubscribeEnabled" Click="EventEnabled_Click" Grid.Column="0"
                                      VerticalAlignment="Center" MinWidth="0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="Subscribe" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock x:Name="SubscribeCustomTag" Text="&#x25C6; custom" FontSize="11" Foreground="#FF8C00" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="&#x1F441;" FontSize="11"
                                    Click="PreviewSubscribe_Click" ToolTipService.ToolTip="Preview"/>
                            <Button Grid.Column="3" Content="&#x25B6;" FontSize="11"
                                    Click="TestSubscribe_Click" ToolTipService.ToolTip="Test"/>
                            <Button Grid.Column="4" Content="&#x270F;" FontSize="11"
                                    Click="EditLayoutSubscribe_Click" ToolTipService.ToolTip="Edit Layout"/>
                        </Grid>
                    </Expander.Header>
                    <StackPanel Spacing="8" Padding="4,6,4,6">
                        <TextBlock Text="Alert text â€” use {user}, {months}"
                                   FontSize="11"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox x:Name="SubscribeText" PlaceholderText="Alert text"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Duration (sec)" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="SubscribeDuration" PlaceholderText="6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="Volume (0â€“1)" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="SubscribeVolume" PlaceholderText="1.0"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox x:Name="SubscribeSound" Grid.Column="0"
                                     PlaceholderText="Sound file (optional)" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="Browse"
                                    Click="BrowseSubscribeSound_Click" FontSize="11"/>
                        </Grid>
                        <Button Content="Save" Click="SaveSubscribe_Click"
                                Style="{ThemeResource AccentButtonStyle}" FontSize="11"/>
                    </StackPanel>
                </Expander>

                <!-- Gift Subscribe -->
                <Expander x:Name="GiftExpander"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="6"
                              Margin="0,2,0,2">
                            <CheckBox x:Name="GiftEnabled" Click="EventEnabled_Click" Grid.Column="0"
                                      VerticalAlignment="Center" MinWidth="0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="Gift Subscribe" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock x:Name="GiftCustomTag" Text="&#x25C6; custom" FontSize="11" Foreground="#FF8C00" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="&#x1F441;" FontSize="11"
                                    Click="PreviewGift_Click" ToolTipService.ToolTip="Preview"/>
                            <Button Grid.Column="3" Content="&#x25B6;" FontSize="11"
                                    Click="TestGift_Click" ToolTipService.ToolTip="Test"/>
                            <Button Grid.Column="4" Content="&#x270F;" FontSize="11"
                                    Click="EditLayoutGift_Click" ToolTipService.ToolTip="Edit Layout"/>
                        </Grid>
                    </Expander.Header>
                    <StackPanel Spacing="8" Padding="4,6,4,6">
                        <TextBlock Text="Alert text â€” use {user}, {target}"
                                   FontSize="11"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox x:Name="GiftText" PlaceholderText="Alert text"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Duration (sec)" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="GiftDuration" PlaceholderText="6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="Volume (0â€“1)" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="GiftVolume" PlaceholderText="1.0"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox x:Name="GiftSound" Grid.Column="0"
                                     PlaceholderText="Sound file (optional)" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="Browse"
                                    Click="BrowseGiftSound_Click" FontSize="11"/>
                        </Grid>
                        <Button Content="Save" Click="SaveGift_Click"
                                Style="{ThemeResource AccentButtonStyle}" FontSize="11"/>
                    </StackPanel>
                </Expander>

                <!-- Bits -->
                <Expander x:Name="BitsExpander"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="6"
                              Margin="0,2,0,2">
                            <CheckBox x:Name="BitsEnabled" Click="EventEnabled_Click" Grid.Column="0"
                                      VerticalAlignment="Center" MinWidth="0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="Bits / Cheers" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock x:Name="BitsCustomTag" Text="&#x25C6; custom" FontSize="11" Foreground="#FF8C00" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="&#x1F441;" FontSize="11"
                                    Click="PreviewBits_Click" ToolTipService.ToolTip="Preview"/>
                            <Button Grid.Column="3" Content="&#x25B6;" FontSize="11"
                                    Click="TestBits_Click" ToolTipService.ToolTip="Test"/>
                            <Button Grid.Column="4" Content="&#x270F;" FontSize="11"
                                    Click="EditLayoutBits_Click" ToolTipService.ToolTip="Edit Layout"/>
                        </Grid>
                    </Expander.Header>
                    <StackPanel Spacing="8" Padding="4,6,4,6">
                        <TextBlock Text="Alert text â€” use {user}, {amount}"
                                   FontSize="11"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox x:Name="BitsText" PlaceholderText="Alert text"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Duration (sec)" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="BitsDuration" PlaceholderText="5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="Volume (0â€“1)" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="BitsVolume" PlaceholderText="1.0"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox x:Name="BitsSound" Grid.Column="0"
                                     PlaceholderText="Sound file (optional)" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="Browse"
                                    Click="BrowseBitsSound_Click" FontSize="11"/>
                        </Grid>
                        <Button Content="Save" Click="SaveBits_Click"
                                Style="{ThemeResource AccentButtonStyle}" FontSize="11"/>
                    </StackPanel>
                </Expander>

                <!-- Raid -->
                <Expander x:Name="RaidExpander"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="6"
                              Margin="0,2,0,2">
                            <CheckBox x:Name="RaidEnabled" Click="EventEnabled_Click" Grid.Column="0"
                                      VerticalAlignment="Center" MinWidth="0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="Raid" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock x:Name="RaidCustomTag" Text="&#x25C6; custom" FontSize="11" Foreground="#FF8C00" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="&#x1F441;" FontSize="11"
                                    Click="PreviewRaid_Click" ToolTipService.ToolTip="Preview"/>
                            <Button Grid.Column="3" Content="&#x25B6;" FontSize="11"
                                    Click="TestRaid_Click" ToolTipService.ToolTip="Test"/>
                            <Button Grid.Column="4" Content="&#x270F;" FontSize="11"
                                    Click="EditLayoutRaid_Click" ToolTipService.ToolTip="Edit Layout"/>
                        </Grid>
                    </Expander.Header>
                    <StackPanel Spacing="8" Padding="4,6,4,6">
                        <TextBlock Text="Alert text â€” use {user}, {amount} for raider count"
                                   FontSize="11"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox x:Name="RaidText" PlaceholderText="Alert text"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Duration (sec)" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="RaidDuration" PlaceholderText="8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="Volume (0â€“1)" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="RaidVolume" PlaceholderText="1.0"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox x:Name="RaidSound" Grid.Column="0"
                                     PlaceholderText="Sound file (optional)" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="Browse"
                                    Click="BrowseRaidSound_Click" FontSize="11"/>
                        </Grid>
                        <Button Content="Save" Click="SaveRaid_Click"
                                Style="{ThemeResource AccentButtonStyle}" FontSize="11"/>
                    </StackPanel>
                </Expander>

                <!-- â”€â”€ GOALS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
                <Expander x:Name="RewardExpander"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="6"
                              Margin="0,2,0,2">
                            <CheckBox x:Name="RewardEnabled" Click="EventEnabled_Click" Grid.Column="0"
                                      VerticalAlignment="Center" MinWidth="0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="Reward Redemption" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock x:Name="RewardCustomTag" Text="&#x25C6; custom" FontSize="11" Foreground="#FF8C00" Visibility="Collapsed" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="&#x1F441;" FontSize="11"
                                    Click="PreviewReward_Click" ToolTipService.ToolTip="Preview"/>
                            <Button Grid.Column="3" Content="&#x25B6;" FontSize="11"
                                    Click="TestReward_Click" ToolTipService.ToolTip="Test"/>
                            <Button Grid.Column="4" Content="&#x270F;" FontSize="11"
                                    Click="EditLayoutReward_Click" ToolTipService.ToolTip="Edit Layout"/>
                        </Grid>
                    </Expander.Header>
                    <StackPanel Spacing="8" Padding="4,6,4,6">
                        <TextBlock Text="Alert text Ã¢â‚¬â€ use {user}, {reward}, {amount}, {input}"
                                   FontSize="11"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox x:Name="RewardText" PlaceholderText="Alert text"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Duration (sec)" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="RewardDuration" PlaceholderText="6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="Volume (0Ã¢â‚¬â€œ1)" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox x:Name="RewardVolume" PlaceholderText="1.0"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox x:Name="RewardSound" Grid.Column="0"
                                     PlaceholderText="Sound file (optional)" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="Browse"
                                    Click="BrowseRewardSound_Click" FontSize="11"/>
                        </Grid>
                        <Button Content="Save" Click="SaveReward_Click"
                                Style="{ThemeResource AccentButtonStyle}" FontSize="11"/>
                    </StackPanel>
                </Expander>

                <!-- ── UNIQUE ALERTS ─────────────────────────────────────────── -->
                <Grid ColumnDefinitions="*,Auto" Margin="2,12,0,4">
                    <TextBlock Grid.Column="0" Text="UNIQUE ALERTS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               CharacterSpacing="80" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="+ Add Alert" Click="AddUniqueAlert_Click" FontSize="11"/>
                </Grid>

                <TextBlock x:Name="NoUniqueAlertsLabel" Text="No unique alerts yet — click Add Alert."
                           FontSize="11" Margin="2,0,0,2"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>

                <ItemsControl x:Name="UniqueAlertsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                      Margin="0,0,0,4">
                                <Expander.Header>
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="6" Margin="0,2,0,2">
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" MinWidth="0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Content="&#x1F441;" FontSize="11"
                                                Click="PreviewUnique_Click" ToolTipService.ToolTip="Preview"/>
                                        <Button Grid.Column="3" Content="&#x25B6;" FontSize="11"
                                                Click="TestUnique_Click" ToolTipService.ToolTip="Test"/>
                                        <Button Grid.Column="4" Content="&#x270F;" FontSize="11"
                                                Click="EditUnique_Click" ToolTipService.ToolTip="Edit Layout"/>
                                        <Button Grid.Column="5" Content="&#x1F5D1;" FontSize="11"
                                                Click="DeleteUnique_Click" ToolTipService.ToolTip="Delete"/>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Spacing="8" Padding="4,6,4,6">
                                    <TextBlock Text="Alert text — use {user}, {arg}" FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBox Text="{Binding Text, Mode=TwoWay}" PlaceholderText="Alert text"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="3">
                                            <TextBlock Text="Duration (sec)" FontSize="11"
                                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                            <TextBox Text="{Binding DurationText, Mode=TwoWay}" PlaceholderText="5"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock Text="Volume (0–1)" FontSize="11"
                                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                            <TextBox Text="{Binding VolumeText, Mode=TwoWay}" PlaceholderText="1.0"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                        <TextBox Grid.Column="0" Text="{Binding SoundFile, Mode=TwoWay}"
                                                 PlaceholderText="Sound file (optional)" IsReadOnly="True"/>
                                        <Button Grid.Column="1" Content="Browse" Click="BrowseUniqueSound_Click" FontSize="11"/>
                                    </Grid>
                                    <Button Content="Save" Click="SaveUnique_Click"
                                            Style="{ThemeResource AccentButtonStyle}" FontSize="11"/>
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── CHANNEL POINT REWARDS ─────────────────────────────────── -->
                <Grid ColumnDefinitions="*,Auto" Margin="2,12,0,4">
                    <TextBlock Grid.Column="0" Text="CHANNEL POINT REWARDS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               CharacterSpacing="80" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="RefreshRewardsBtn" Content="Refresh from Twitch/Kick"
                            Click="RefreshRewards_Click" FontSize="11"/>
                </Grid>

                <TextBlock x:Name="RewardsStatusLabel"
                           Text="Assign a unique alert to a reward. Refresh pulls your rewards from each platform (Kick needs a re-login for the new permission)."
                           FontSize="11" Margin="2,0,0,4" TextWrapping="Wrap"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>

                <ItemsControl x:Name="RewardsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,0,0,4">
                                <TextBlock Grid.Column="0" Text="{Binding Display}" FontSize="13"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <ComboBox Grid.Column="1" MinWidth="160"
                                          ItemsSource="{Binding ElementName=RewardsList, Path=DataContext.RewardAlertOptions}"
                                          SelectedItem="{Binding AssignedAlert, Mode=TwoWay}"
                                          SelectionChanged="RewardAlertAssign_Changed"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="GOALS" FontSize="10" FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           Margin="2,12,0,4" CharacterSpacing="80"/>

                <!-- Goal expanders built in code-behind (dynamic list) -->
                <StackPanel x:Name="GoalListPanel" Spacing="4"/>

                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                    <Button Content="+ Add Goal" Click="AddGoal_Click" FontSize="11"/>
                    <Button Content="Remove Selected" Click="RemoveGoal_Click" FontSize="11"/>
                    <Button Content="Push All" Click="PushAllGoals_Click" FontSize="11"/>
                </StackPanel>

                <!-- â”€â”€ LABELS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
                <TextBlock Text="LABELS" FontSize="10" FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           Margin="2,12,0,4" CharacterSpacing="80"/>

                <ListView x:Name="LabelList" SelectionMode="None" MaxHeight="360"
                          HorizontalContentAlignment="Stretch">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="6" Padding="0,3">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding Size}" FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock Text="{Binding Status}" FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="&#x1F441;" FontSize="11"
                                        VerticalAlignment="Center"
                                        Click="PreviewLabel_Click" ToolTipService.ToolTip="Preview"/>
                                <Button Grid.Column="2" Content="&#x25B6;" FontSize="11"
                                        VerticalAlignment="Center"
                                        Click="TestLabel_Click" ToolTipService.ToolTip="Test"/>
                                <Button Grid.Column="3" Content="&#x2715;" FontSize="11"
                                        VerticalAlignment="Center"
                                        Click="ClearLabel_Click" ToolTipService.ToolTip="Clear"/>
                                <Button Grid.Column="4" Content="&#x270F;" FontSize="11"
                                        VerticalAlignment="Center"
                                        Click="EditLabelLayout_Click" ToolTipService.ToolTip="Edit Layout"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                    <Button Content="Push All" Click="PushAllLabels_Click" FontSize="11"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- â”€â”€ Right column: preview panel â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*">

            <Border Grid.Row="0" Padding="12,8"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock x:Name="PreviewTitle"
                               Text="Select an item and click Preview"
                               VerticalAlignment="Center" FontSize="13"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <Button x:Name="ReplayBtn" Content="&#x21BA; Replay"
                            Click="Replay_Click" IsEnabled="False" FontSize="12"/>
                    <TextBlock x:Name="PreviewTimeLabel" Text=""
                               VerticalAlignment="Center" FontSize="12"
                               FontFamily="Consolas" MinWidth="52"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Background="#111111">
                <Viewbox x:Name="PreviewViewbox" Stretch="Uniform"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Canvas x:Name="PreviewCanvas" Width="1920" Height="1080"
                            Background="#121212"/>
                </Viewbox>
                <TextBlock x:Name="PreviewHint"
                           Text="Click Preview on an overlay item to see its layout here"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="16" Opacity="0.4"/>
            </Grid>

        </Grid>

    </Grid>
</Page>
