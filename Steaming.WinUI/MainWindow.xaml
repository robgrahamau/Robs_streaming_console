<Window
    x:Class="Steaming.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Streaming">

    <Grid>
      <Grid RowDefinitions="*,Auto">

        <!-- Main navigation -->
        <NavigationView x:Name="NavView"
                        Grid.Row="0"
                        IsSettingsVisible="False"
                        SelectionChanged="NavView_SelectionChanged"
                        PaneTitle="Rob's Streaming Console"
                        OpenPaneLength="200"
                        CompactModeThresholdWidth="1000"
                        RequestedTheme="Dark">

            <NavigationView.MenuItems>
                <NavigationViewItemHeader Content="STREAM"/>
                <NavigationViewItem x:Name="NavDashboard" Tag="Dashboard"  Content="Dashboard"/>
                <NavigationViewItem Tag="Stream"           Content="Stream Management"/>
                <NavigationViewItem Tag="Viewers"          Content="Viewers"/>
                <NavigationViewItem Tag="Activity"         Content="Activity"/>

                <NavigationViewItemSeparator/>
                <NavigationViewItemHeader Content="CONFIGURE"/>
                <NavigationViewItem Tag="Overlays"     Content="Overlays"/>
                <NavigationViewItem Tag="Chat"         Content="Chat"/>
                <NavigationViewItem Tag="Chatbot"      Content="Chatbot"/>
                <NavigationViewItem Tag="EmojiRain"    Content="Emoji Rain"/>
                <NavigationViewItem Tag="Music"        Content="Music"/>
                <NavigationViewItem Tag="Analytics"    Content="Analytics"/>
                <NavigationViewItem Tag="Avatar"       Content="Avatar"/>

                <NavigationViewItemSeparator/>
                <NavigationViewItemHeader Content="SYSTEM"/>
                <NavigationViewItem Tag="Status"       Content="Runtime Status"/>
                <NavigationViewItem x:Name="NavConnections" Tag="Connections"  Content="Connections"/>
                <NavigationViewItem Tag="ObsConfig"    Content="OBS Config"/>
                <NavigationViewItem Tag="Settings"     Content="Settings"/>
                <NavigationViewItem Tag="About"        Content="About"/>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>

        <!-- Status bar -->
        <Border Grid.Row="1"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: live + connection status -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">

                    <!-- Live indicator -->
                    <Ellipse x:Name="LiveDot" Width="8" Height="8"/>
                    <TextBlock x:Name="LiveStatusText" FontSize="11" FontWeight="SemiBold" Margin="0,0,16,0"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>

                    <!-- Stream health pill (OBS / Twitch / Kick live state) -->
                    <Border x:Name="HealthPill" CornerRadius="4" Padding="6,1" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock x:Name="HealthPillText" FontSize="11" FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Border>
                    <TextBlock x:Name="HealthWarningText" FontSize="11" FontWeight="SemiBold" Margin="0,0,16,0"
                               VerticalAlignment="Center"/>

                    <!-- Twitch -->
                    <Ellipse x:Name="TwitchDot" Width="8" Height="8"
                             Fill="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock x:Name="TwitchStatusText" FontSize="11" Margin="4,0,16,0"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>

                    <!-- Kick -->
                    <Ellipse x:Name="KickDot" Width="8" Height="8"
                             Fill="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock x:Name="KickStatusText" FontSize="11" Margin="4,0,16,0"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>

                    <!-- OBS Plugin Pipe -->
                    <Ellipse x:Name="PipeDot" Width="8" Height="8"
                             Fill="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock x:Name="PipeStatusText" FontSize="11" Margin="4,0,0,0"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>

                <!-- Right: version -->
                <TextBlock x:Name="VersionText" Grid.Column="1" FontSize="11" VerticalAlignment="Center"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            </Grid>
        </Border>
      </Grid>

      <!-- Invisible host for headless WebView2 work (e.g. Kick chatroom-id lookup past Cloudflare). -->
      <Grid x:Name="HiddenWebHost" Width="0" Height="0" Opacity="0" IsHitTestVisible="False"/>

    </Grid>
</Window>
