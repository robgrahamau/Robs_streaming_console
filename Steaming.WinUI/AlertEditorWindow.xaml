<Window
    x:Class="Steaming.WinUI.AlertEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="6,4"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <ScrollViewer HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Hidden">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">

                    <Button x:Name="PlayBtn" Content="&#x25B6; Play" Click="PlayBtn_Click"/>
                    <Button x:Name="StopBtn" Content="&#x23F9;" Click="StopBtn_Click"/>
                    <TextBlock x:Name="TimeLabel" Text="0.00s" VerticalAlignment="Center" MinWidth="52"/>

                    <Border Width="1" Margin="4,4" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <Button x:Name="UndoBtn" Content="Undo" Click="UndoBtn_Click" FontSize="12" IsEnabled="False"/>
                    <Button x:Name="RedoBtn" Content="Redo" Click="RedoBtn_Click" FontSize="12" IsEnabled="False"/>

                    <Border Width="1" Margin="4,4" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <Button x:Name="AddElemBtn" Content="+ Add">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Text" Click="AddText_Click"/>
                                <MenuFlyoutItem Text="Rectangle" Click="AddRect_Click"/>
                                <MenuFlyoutItem Text="Goal Bar" Click="AddGoalBar_Click"/>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Image..." Click="AddImage_Click"/>
                                <MenuFlyoutItem Text="GIF..." Click="AddGif_Click"/>
                                <MenuFlyoutItem Text="Video..." Click="AddVideo_Click"/>
                                <MenuFlyoutItem Text="Audio Clip..." Click="AddAudio_Click"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button x:Name="DeleteElemBtn" Content="Delete" Click="DeleteElem_Click"/>

                    <Border Width="1" Margin="4,4" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <TextBlock Text="W:" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox x:Name="CanvasW" Width="54" PlaceholderText="1920"/>
                    <TextBlock Text="H:" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox x:Name="CanvasH" Width="54" PlaceholderText="1080"/>
                    <Button x:Name="ResizeBtn" Content="Resize" Click="ResizeCanvas_Click" FontSize="12"/>

                    <Border Width="1" Margin="4,4" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <TextBlock Text="Duration:" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox x:Name="DurationBox" Width="54" PlaceholderText="5.0" KeyDown="DurationBox_KeyDown" LostFocus="DurationBox_LostFocus"/>
                    <Button Content="Apply" FontSize="12" Click="ApplyDuration_Click"/>

                    <Border Width="1" Margin="4,4" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <Button x:Name="ImportBtn" Content="Import..." Click="ImportLayout_Click" FontSize="12"/>
                    <Button x:Name="ExportBtn" Content="Export..." Click="ExportLayout_Click" FontSize="12"/>

                    <Border Width="1" Margin="4,4" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <Button x:Name="SaveBtn" Content="Save" Click="SaveBtn_Click"
                            Style="{ThemeResource AccentButtonStyle}"/>
                    <Button x:Name="CancelBtn" Content="Cancel" Click="CancelBtn_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- DockManager is created in code-behind and placed here -->
        <Grid x:Name="DockHost" Grid.Row="1"/>

    </Grid>
</Window>
